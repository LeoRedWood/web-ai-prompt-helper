{
    "manifest_version": 3,
    "name": "web-ai-prompt-helper",
    "version": "0.1",
    "description": "An extension for web ai prompt enhancement",
    "host_permissions": ["https://chat.deepseek.com/*"],
    "web_accessible_resources": [
        {
            "resources": ["templates.json", "icons/*", "prompts/*"],
            "matches": ["https://chat.deepseek.com/*"]
        }
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_title": "管理提示词"
    },
    "content_scripts": [
        {
            "matches": ["https://chat.deepseek.com/*"],
            "js": ["src/platforms/deepseek.js", "src/content.js"],
            "run_at": "document_idle"
        }
    ]
}